datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files       File[]
  collections Collection[]
}

model File {
  id           String       @id @default(cuid())
  name         String
  originalName String
  type         String
  extension    String
  size         Int
  storageKey   String
  ownerId      String
  users        String[]     @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sharedLinks  SharedLink[]
  submissions  Submission[]
}

model SharedLink {
  id            String    @id @default(cuid())
  token         String    @unique
  documentId    String
  createdBy     String
  password      String?   // hashed password
  expiresAt     DateTime?
  allowDownload Boolean   @default(true)
  isActive      Boolean   @default(true)
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  file          File      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("shared_links")
}

model Collection {
  id              String   @id @default(cuid())
  title           String
  description     String?
  ownerId         String
  isActive        Boolean  @default(true)
  collectionToken String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categories Category[]

  @@map("collections")
}

model Category {
  id           String   @id @default(cuid())
  collectionId String
  name         String
  description  String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection   Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  requirements Requirement[]

  @@map("categories")
}

model Requirement {
  id                 String       @id @default(cuid())
  categoryId         String
  title              String
  description        String?
  uploadToken        String       @unique
  deadline           DateTime?
  allowMultipleFiles Boolean      @default(false)
  maxFileSize        Int          @default(10485760) // default 10MB
  acceptedFileTypes  String[]     @default([])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("requirements")
}

model Submission {
  id                String    @id @default(cuid())
  requirementId     String
  fileId            String
  studentName       String
  studentRollNumber String
  studentEmail      String?
  remarks           String?
  status            String    @default("Pending") // Pending, Reviewed, Approved, Rejected
  submittedAt       DateTime  @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  file        File        @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("submissions")
}
