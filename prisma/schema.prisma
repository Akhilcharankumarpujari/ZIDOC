datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files     File[]
}

model File {
  id           String   @id @default(cuid())
  name         String
  originalName String
  type         String
  extension    String
  size         Int
  storageKey   String
  ownerId      String
  users        String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}
