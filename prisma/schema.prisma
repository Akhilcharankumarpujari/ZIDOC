datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files     File[]
}

model File {
  id           String       @id @default(cuid())
  name         String
  originalName String
  type         String
  extension    String
  size         Int
  storageKey   String
  ownerId      String
  users        String[]     @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sharedLinks  SharedLink[]
}

model SharedLink {
  id            String    @id @default(cuid())
  token         String    @unique
  documentId    String
  createdBy     String
  password      String?   // hashed password
  expiresAt     DateTime?
  allowDownload Boolean   @default(true)
  isActive      Boolean   @default(true)
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  file          File      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("shared_links")
}
