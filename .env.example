DATABASE_URL="postgresql://postgres:postgres@localhost:5432/storeit?schema=public"

# JWT Authentication Configuration
# Generate a secret using a secure random string creator
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# S3 / MinIO Storage Configuration
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="storeit"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"